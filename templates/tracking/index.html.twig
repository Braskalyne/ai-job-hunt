{% extends 'base.html.twig' %}

{% block title %}Suivi - Ai Job Hunt{% endblock %}

{% block body %}
    <div class="layout">
        <header class="topbar">
            <div class="topbar__inner">
                <div class="topbar__left">
                    <a class="brand brand--link" href="{{ path('app_home') }}">
                        <span class="brand__dot"></span>
                        <span>Ai Job Hunt</span>
                    </a>
                    {% if app.user %}
                        <nav class="topbar__nav" aria-label="Navigation principale">
                            <a class="topbar__nav-link" href="{{ path('app_jobs') }}">Jobs</a>
                            <a class="topbar__nav-link is-active" href="{{ path('app_tracking') }}">Suivi</a>
                        </nav>
                    {% endif %}
                </div>
                <div class="topbar__actions">
                    <a class="btn btn--ghost btn--small" href="{{ path('app_logout') }}">Logout</a>
                    <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Basculer le theme" title="Basculer le theme">
                        <span class="theme-toggle__icon" aria-hidden="true">☀️</span>
                    </button>
                </div>
            </div>
        </header>

        <main class="tracking">
            <div class="tracking__header">
                <h1>Suivi des candidatures</h1>
                <p>Glissez-déposez les cartes pour changer leur statut</p>
            </div>

            <div class="kanban">
                {% for status, label in columns %}
                    <div class="kanban__column" data-status="{{ status }}">
                        <div class="kanban__column-header">
                            <h2 class="kanban__column-title">{{ label }}</h2>
                            <span class="kanban__column-count">{{ applicationsByStatus[status]|length }}</span>
                        </div>

                        <div class="kanban__column-body" data-column="{{ status }}">
                            {% if applicationsByStatus[status] is empty %}
                                <div class="kanban__empty">Aucune candidature</div>
                            {% else %}
                                {% for application in applicationsByStatus[status] %}
                                    {% set job = application.jobOffer %}
                                    <div class="kanban-card" draggable="true" data-application-id="{{ application.id }}">
                                        <div class="kanban-card__header">
                                            <h3 class="kanban-card__title">
                                                <a href="{{ job.url }}" target="_blank" rel="noopener noreferrer">{{ job.title }}</a>
                                            </h3>
                                        </div>
                                        <div class="kanban-card__meta">
                                            <span class="kanban-card__company">{{ job.company }}</span>
                                            {% if job.location %}
                                                <span class="kanban-card__location">{{ job.location }}</span>
                                            {% endif %}
                                        </div>
                                        {% if application.appliedAt %}
                                            <div class="kanban-card__footer">
                                                <span class="kanban-card__date">Postulé le {{ application.appliedAt|date('d/m/Y') }}</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </main>

        <footer class="footer">
            <div class="footer__inner">
                <nav class="footer__links">
                    <a href="{{ path('app_legal_notice') }}" class="footer__link">Mentions légales</a>
                    <a href="{{ path('app_privacy_policy') }}" class="footer__link">Politique de confidentialité</a>
                    <a href="{{ path('app_terms') }}" class="footer__link">CGU</a>
                </nav>
                <p class="footer__copyright">&copy; {{ "now"|date("Y") }} Ai Job Hunt. Tous droits réservés.</p>
            </div>
        </footer>
    </div>

    <script>
        (function () {
            // Theme toggle
            const storageKey = 'theme-preference';
            const toggleButton = document.getElementById('theme-toggle');
            const toggleIcon = toggleButton ? toggleButton.querySelector('.theme-toggle__icon') : null;
            const body = document.body;

            if (toggleButton) {
                const applyTheme = (theme) => {
                    const isLight = theme === 'light';
                    body.classList.toggle('light-theme', isLight);
                    if (toggleIcon) {
                        toggleIcon.textContent = isLight ? '🌙' : '☀️';
                    }
                    toggleButton.setAttribute('aria-label', isLight ? 'Passer en mode sombre' : 'Passer en mode clair');
                    toggleButton.setAttribute('title', isLight ? 'Passer en mode sombre' : 'Passer en mode clair');
                };

                const savedTheme = localStorage.getItem(storageKey);
                if (savedTheme === 'light' || savedTheme === 'dark') {
                    applyTheme(savedTheme);
                } else {
                    applyTheme('dark');
                }

                toggleButton.addEventListener('click', function () {
                    const nextTheme = body.classList.contains('light-theme') ? 'dark' : 'light';
                    localStorage.setItem(storageKey, nextTheme);
                    applyTheme(nextTheme);
                });
            }

            // Kanban drag & drop
            let draggedCard = null;
            let sourceColumn = null;

            document.querySelectorAll('.kanban-card').forEach(card => {
                card.addEventListener('dragstart', function (e) {
                    draggedCard = this;
                    sourceColumn = this.closest('.kanban__column-body');
                    this.classList.add('is-dragging');
                    e.dataTransfer.effectAllowed = 'move';
                });

                card.addEventListener('dragend', function () {
                    this.classList.remove('is-dragging');
                    draggedCard = null;
                    sourceColumn = null;
                });
            });

            document.querySelectorAll('.kanban__column-body').forEach(column => {
                column.addEventListener('dragover', function (e) {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = 'move';
                    this.classList.add('is-drag-over');
                });

                column.addEventListener('dragleave', function () {
                    this.classList.remove('is-drag-over');
                });

                column.addEventListener('drop', function (e) {
                    e.preventDefault();
                    this.classList.remove('is-drag-over');

                    if (!draggedCard || sourceColumn === this) {
                        return;
                    }

                    const applicationId = draggedCard.dataset.applicationId;
                    const newStatus = this.dataset.column;

                    // Optimistic UI update
                    this.appendChild(draggedCard);
                    updateColumnCounts();
                    removeEmptyMessages();

                    // Send to server
                    fetch(`/tracking/${applicationId}/move`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ status: newStatus })
                    })
                    .then(response => {
                        if (!response.ok) {
                            // Revert on error
                            sourceColumn.appendChild(draggedCard);
                            updateColumnCounts();
                            alert('Erreur lors du déplacement de la carte');
                        }
                    })
                    .catch(() => {
                        // Revert on error
                        sourceColumn.appendChild(draggedCard);
                        updateColumnCounts();
                        alert('Erreur réseau');
                    });
                });
            });

            function updateColumnCounts() {
                document.querySelectorAll('.kanban__column').forEach(column => {
                    const count = column.querySelectorAll('.kanban-card').length;
                    const countEl = column.querySelector('.kanban__column-count');
                    if (countEl) {
                        countEl.textContent = count;
                    }
                });
            }

            function removeEmptyMessages() {
                document.querySelectorAll('.kanban__column-body').forEach(column => {
                    const hasCards = column.querySelectorAll('.kanban-card').length > 0;
                    const emptyMsg = column.querySelector('.kanban__empty');
                    if (hasCards && emptyMsg) {
                        emptyMsg.remove();
                    } else if (!hasCards && !emptyMsg) {
                        const empty = document.createElement('div');
                        empty.className = 'kanban__empty';
                        empty.textContent = 'Aucune candidature';
                        column.appendChild(empty);
                    }
                });
            }
        })();
    </script>
{% endblock %}
